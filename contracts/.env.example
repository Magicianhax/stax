# Deployer key (use a throwaway key with a small MNT balance for gas)
PRIVATE_KEY=

# RPCs
MANTLE_RPC_URL=https://rpc.mantle.xyz
MANTLE_SEPOLIA_RPC_URL=https://rpc.sepolia.mantle.xyz

# Etherscan API key (V2 multichain — covers Mantle verification, free tier) — https://etherscan.io/apis
ETHERSCAN_API_KEY=

# Off-chain agent signer (the EIP-712 risk-inference signer; its address is set as trusted in InferenceVerifier)
AGENT_SIGNER_ADDRESS=
