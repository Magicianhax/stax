# Stax web env — committed template. Copy to .env.local and fill in. Do NOT put real secrets here.

# Chain (Mantle mainnet)
NEXT_PUBLIC_CHAIN_ID=5000
NEXT_PUBLIC_MANTLE_RPC_URL=https://rpc.mantle.xyz
NEXT_PUBLIC_USDC_ADDRESS=0x09Bc4E0D864854c6aFB6eB9A9cdF58aC190D0dF9
NEXT_PUBLIC_FLUXION_ROUTER=0x5628a59dF0ECAC3f3171f877A94bEb26BA6DFAa0

# Privy — https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# Pimlico — https://dashboard.pimlico.io
PIMLICO_API_KEY=

# Alchemy (server-side) — https://dashboard.alchemy.com (create a Mantle Mainnet app).
# Powers the Wallet transaction history (getAssetTransfers falls back to an ERC-20
# log scan on Mantle) and better RPC. To route all client reads through Alchemy too,
# set NEXT_PUBLIC_MANTLE_RPC_URL to https://mantle-mainnet.g.alchemy.com/v2/<key>.
ALCHEMY_API_KEY=

# Transak — https://transak.com
NEXT_PUBLIC_TRANSAK_API_KEY=
NEXT_PUBLIC_TRANSAK_ENVIRONMENT=STAGING

# AI via direct Anthropic API — https://console.anthropic.com (sk-ant-...)
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-6

# Stax AI agent EIP-712 signer (server-only) — generate with: see contracts/scripts genSigner
AGENT_SIGNER_PRIVATE_KEY=

# Deployed contract addresses (from deploy script)
NEXT_PUBLIC_STAX_EXECUTOR=
NEXT_PUBLIC_INFERENCE_VERIFIER=
NEXT_PUBLIC_IDENTITY_REGISTRY=
NEXT_PUBLIC_STAX_AGENT_ID=
# Block the executor was deployed at — bounds event-log scans (history/activity).
NEXT_PUBLIC_STAX_EXECUTOR_BLOCK=

# Etherscan V2 API key (free) — https://etherscan.io/myapikey. One key works across
# chains incl. Mantle (chainid 5000). Powers the Wallet transaction history
# (indexed account/tokentx — fast, no block-range limits like Alchemy free tier).
ETHERSCAN_API_KEY=

# Autopilot (autonomous delegated agent) — Privy Wallet API authorization key
# (dashboard → enable session signers, create authorization key) + a random cron secret.
PRIVY_AUTHORIZATION_KEY=
AUTOPILOT_CRON_SECRET=

# Platform fee — basis points on capital deployed (buys + AI invests). 25 = 0.25%.
# Treasury receives the fee (defaults to the deployer if unset).
NEXT_PUBLIC_STAX_FEE_BPS=25
NEXT_PUBLIC_STAX_TREASURY=
