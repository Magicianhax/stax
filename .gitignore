# Stax — repo root ignore (web/ and contracts/ also have their own)

# dependencies
**/node_modules/

# secrets — NEVER commit real env. The .env.example templates ARE committed.
.env
.env.local
**/.env
**/.env.local
**/.env.*.local

# next.js / build output
**/.next/
**/out/
**/build/
**/*.tsbuildinfo
**/next-env.d.ts

# hardhat / solidity build artifacts
**/artifacts/
**/cache/
**/typechain-types/
**/coverage/
**/coverage.json

# internal planning notes — not for the public repo
tasks/

# personal / submission + marketing helper docs — local only.
# Contain the owner's email and private notes; never commit.
# (BRAND.md, SPEC.md, PRODUCT-BRIEF.md, demo.gif stay tracked — they're public.)
docs/BUIDL_*
docs/X_WEEK_PLAN.md

# demo / marketing video project — kept local only, never committed
video/

# os / editor / misc
.DS_Store
Thumbs.db
*.pem
*.log
**/.vercel
